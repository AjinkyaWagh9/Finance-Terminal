# FINTERMINAL — environment template. Copy to .env and fill in.

# Anthropic — used for /analyze if supervisor.primary in agents.yaml is a Claude model
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used for /analyze if supervisor.primary in agents.yaml is a gpt-* model
# Cheaper alternative to Claude (gpt-5-mini ~10x cheaper, gpt-5-nano ~60x cheaper).
# Only one of ANTHROPIC_API_KEY or OPENAI_API_KEY is strictly required, depending on agents.yaml.
OPENAI_API_KEY=sk-proj-...

# xAI Grok — Phase 2.5 only, optional (sentiment module)
GROK_API_KEY=
SENTIMENT_ENABLED=false

# OpenBB — sign up at https://my.openbb.co for the PAT
OPENBB_PAT=

# Storage paths (relative to repo root)
DUCKDB_PATH=./data/finterminal.duckdb
SQLITE_PATH=./data/finterminal.sqlite
CHROMA_PATH=./data/chroma

# LLM call log
LLM_CALLS_PATH=./logs/llm_calls.jsonl

# Logging
LOG_LEVEL=INFO
