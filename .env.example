# FINTERMINAL — environment template. Copy to .env and fill in.

# Anthropic — required from Day 5 (/analyze command)
ANTHROPIC_API_KEY=sk-ant-...

# xAI Grok — Phase 2.5 only, optional (sentiment module)
GROK_API_KEY=
SENTIMENT_ENABLED=false

# OpenBB — sign up at https://my.openbb.co for the PAT
OPENBB_PAT=

# Storage paths (relative to repo root)
DUCKDB_PATH=./data/finterminal.duckdb
SQLITE_PATH=./data/finterminal.sqlite
CHROMA_PATH=./data/chroma

# LLM call log
LLM_CALLS_PATH=./logs/llm_calls.jsonl

# Logging
LOG_LEVEL=INFO
